    "uuid": "^11.1.1"
  },
  "dependencies": {
    "apple-signin-auth": "^2.0.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.21.1",
